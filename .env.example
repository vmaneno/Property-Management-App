# Copy this to .env.local for local development
# Add these as Environment Variables in Vercel dashboard

# Supabase connection string (use the "Transaction Pooler" URL from Supabase → Settings → Database)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Random secret for signing JWT tokens — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# ── M-Pesa (Safaricom Daraja API) ─────────────────────────────────────────────
# Get Consumer Key & Secret from developer.safaricom.co.ke → My Apps
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here

# Passkey — from developer.safaricom.co.ke → My Apps (needed for STK Push)
MPESA_PASSKEY=your_passkey_here

# Paybill / Till shortcode — sandbox: 174379 | production: your real shortcode
MPESA_SHORTCODE=174379

# Set to "sandbox" while testing, "production" when going live
MPESA_ENV=sandbox

# Your deployed Vercel URL — used by Safaricom to send payment notifications
MPESA_C2B_CONFIRM_URL=https://your-app.vercel.app/api/mpesa/c2b/confirm
MPESA_C2B_VALIDATE_URL=https://your-app.vercel.app/api/mpesa/c2b/validate
